---
import "/src/styles/global.css";
import { ClientRouter } from "astro:transitions";
import TopBar from "../components/TopBar.astro";
import Footer from "../components/Footer.astro";
import Masthead from "../components/Masthead.astro";
import { CustomCursor } from "../components/CustomCursor";
import AmbientBackground from "../components/AmbientBackground";
import CursorBloom from "../components/CursorBloom";
import SEOHead from "../components/SEOHead.astro";
import PortfolioShell from "../components/PortfolioShell";

interface Props {
    title: string;
    description?: string;
    ogImage?: string;
    siteName?: string;
    instagramUrl?: string;
    masthead?: { name: string; yearRange: string };
}

const { title, description, ogImage, siteName, instagramUrl, masthead } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
        <link href="https://api.fontshare.com/v2/css?f[]=general-sans@300,400,500,600&display=swap" rel="stylesheet" />
        <title>{title}</title>
        <SEOHead title={title} description={description} ogImage={ogImage} siteName={siteName} />
        <ClientRouter />
    </head>

    <body
        class="w-full mx-auto bg-neutral-900 text-neutral-400 min-h-screen cursor-none"
    >
        <AmbientBackground client:only="react" />
        <CursorBloom client:only="react" />
        <CustomCursor client:load transition:persist />

        <TopBar instagramUrl={instagramUrl} markBehavior={masthead ? "reveal-on-scroll" : "visible"} />

        {masthead && <Masthead name={masthead.name} yearRange={masthead.yearRange} />}

        <main class="min-h-[100svh]">
            <slot />
            <PortfolioShell client:only="react" transition:persist="portfolio-shell" />
        </main>

        <Footer />
    </body>
</html>
