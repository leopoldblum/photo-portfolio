---
import "/src/styles/global.css";
import { ClientRouter } from "astro:transitions";
import TopBar from "../components/TopBar.astro";
import Footer from "../components/Footer.astro";
import Masthead from "../components/Masthead.astro";
import { CustomCursor } from "../components/CustomCursor";
import CursorBloom from "../components/CursorBloom";
import SEOHead from "../components/SEOHead.astro";
import PortfolioShell from "../components/PortfolioShell";

interface Props {
    title: string;
    description?: string;
    ogImage?: string;
    siteName?: string;
    instagramUrl?: string;
    masthead?: { name: string; yearRange: string; align?: "left" | "right" };
    revealMarkOnScroll?: boolean;
}

const { title, description, ogImage, siteName, instagramUrl, masthead, revealMarkOnScroll = false } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400;0,6..96,500;0,6..96,700;1,6..96,400;1,6..96,500;1,6..96,700;1,6..96,800&display=swap"
            rel="stylesheet"
        />
        <link href="https://api.fontshare.com/v2/css?f[]=general-sans@300,400,500,600&display=swap" rel="stylesheet" />
        <title>{title}</title>
        <SEOHead title={title} description={description} ogImage={ogImage} siteName={siteName} />
        <ClientRouter />
    </head>

    <body
        class="w-full mx-auto text-neutral-300 min-h-screen cursor-none"
    >
        <!-- atmosphere stack — static washes, vignette, grain. No breathing animation. -->
        <div class="atm-lights" aria-hidden="true"></div>
        <div class="atm-vignette" aria-hidden="true"></div>
        <CursorBloom client:only="react" transition:persist="cursor-bloom" />
        <div class="atm-grain" aria-hidden="true"></div>

        <!-- registration corner crosses -->
        <span class="atm-reg atm-reg-tl" aria-hidden="true"></span>
        <span class="atm-reg atm-reg-tr" aria-hidden="true"></span>
        <span class="atm-reg atm-reg-bl" aria-hidden="true"></span>
        <span class="atm-reg atm-reg-br" aria-hidden="true"></span>

        <CustomCursor client:load transition:persist />

        <TopBar instagramUrl={instagramUrl} markBehavior={revealMarkOnScroll ? "reveal-on-scroll" : "visible"} />

        {masthead && <Masthead name={masthead.name} yearRange={masthead.yearRange} align={masthead.align} />}

        <main class="min-h-[100svh]">
            <slot />
            <PortfolioShell client:only="react" transition:persist="portfolio-shell" />
        </main>

        <Footer />
    </body>
</html>
