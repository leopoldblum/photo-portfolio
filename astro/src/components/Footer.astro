---
const year = new Date().getFullYear();
---

<footer
    id="site-footer"
    class="flex items-center gap-4 md:gap-6 w-[93vw] mx-auto py-7 md:py-9 select-none"
>
    <span class="footer-text footer-text-left text-[10px] tracking-[0.3em] uppercase text-neutral-500/40">
        © Leopold Blum {year}
    </span>
    <div class="footer-line flex-1 h-px bg-neutral-700/40"></div>
    <span class="footer-text footer-text-right text-[10px] tracking-[0.3em] uppercase text-neutral-500/40">
        Berlin
    </span>
</footer>

<style>
    .footer-text {
        line-height: 1;
        opacity: 0;
        transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .footer-line {
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.15s;
    }

    #site-footer.is-visible .footer-text {
        opacity: 1;
    }

    #site-footer.is-visible .footer-text-right {
        transition-delay: 0.4s;
    }

    #site-footer.is-visible .footer-line {
        transform: scaleX(1);
    }

    @media (prefers-reduced-motion: reduce) {
        .footer-text,
        .footer-line {
            transition: none;
        }
    }
</style>

<script>
    function setupFooterReveal() {
        const footer = document.getElementById("site-footer");
        if (!footer) return;
        const observer = new IntersectionObserver(
            ([entry]) => {
                if (entry.isIntersecting) {
                    footer.classList.add("is-visible");
                    observer.disconnect();
                }
            },
            { rootMargin: "0px 0px -10% 0px" }
        );
        observer.observe(footer);
    }

    setupFooterReveal();
    document.addEventListener("astro:after-swap", setupFooterReveal);
</script>
