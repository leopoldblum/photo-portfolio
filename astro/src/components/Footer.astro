---
const year = new Date().getFullYear();
---

<footer
    id="site-footer"
    class="flex items-center gap-4 md:gap-6 w-[93vw] mx-auto py-7 md:py-9 select-none"
>
    <span class="footer-text footer-text-left text-[10px] tracking-[0.3em] uppercase text-neutral-300/85">
        © Leopold Blum {year}
    </span>
    <div class="footer-line flex-1 h-px bg-neutral-700/40"></div>
    <span class="footer-text footer-text-right text-[10px] tracking-[0.3em] uppercase text-neutral-300/85">
        Berlin
    </span>
</footer>

<style>
    .footer-text {
        line-height: 1;
    }
</style>
