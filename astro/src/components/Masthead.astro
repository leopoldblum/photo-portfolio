---
interface Props {
    name: string;
    yearRange: string;
    align?: "left" | "right";
}

const { name, yearRange, align = "left" } = Astro.props;
const isRight = align === "right";
---

<section
    id="masthead"
    class:list={["masthead", "w-[93vw] mx-auto pt-10 md:pt-20 pb-12 md:pb-20 select-none", isRight && "masthead--right"]}
>
    <h1 class="masthead-name text-neutral-100/90">{name}</h1>
    <div class="masthead-row">
        <span class="masthead-dash" aria-hidden="true">—</span>
        <span class="masthead-rule" aria-hidden="true"></span>
        <span class="masthead-meta text-neutral-500/70">photographs · {yearRange}</span>
    </div>
</section>

<style>
    .masthead {
        font-feature-settings: "ss01", "ss02";
        padding-left: clamp(2rem, 10vw, 9rem);
    }

    .masthead-name {
        font-family: "Bodoni Moda", serif;
        font-style: italic;
        font-weight: 400;
        font-size: clamp(2.75rem, 7vw, 5.5rem);
        line-height: 0.95;
        letter-spacing: -0.015em;
        margin: 0;
        animation: maFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
    }

    .masthead-row {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        margin-top: 1.4rem;
    }

    .masthead--right {
        text-align: right;
        padding-right: clamp(2rem, 10vw, 9rem);
    }

    .masthead--right .masthead-row {
        flex-direction: row-reverse;
    }

    .masthead--right .masthead-rule {
        transform-origin: right center;
        background: linear-gradient(
            to left,
            rgb(115 115 115 / 0.45),
            rgb(115 115 115 / 0)
        );
    }

    .masthead-dash {
        font-family: "Bodoni Moda", serif;
        font-style: italic;
        color: rgb(163 163 163 / 0.5);
        font-size: 1rem;
        line-height: 1;
        animation: maFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.65s both;
    }

    .masthead-rule {
        flex: 1;
        height: 1px;
        max-width: 18rem;
        background: linear-gradient(
            to right,
            rgb(115 115 115 / 0.45),
            rgb(115 115 115 / 0)
        );
        transform-origin: left center;
        transform: scaleX(0);
        animation: maDrawLine 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.55s both;
    }

    .masthead-meta {
        font-family: "General Sans", system-ui, sans-serif;
        font-weight: 400;
        font-size: 0.7rem;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        white-space: nowrap;
        animation: maFade 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.8s both;
    }

    @keyframes maFadeUp {
        from {
            opacity: 0;
            transform: translateY(0.6rem);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes maFade {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @keyframes maDrawLine {
        from {
            transform: scaleX(0);
        }
        to {
            transform: scaleX(1);
        }
    }

    @media (max-width: 640px) {
        .masthead-row {
            gap: 0.65rem;
            margin-top: 1rem;
        }
        .masthead-rule {
            max-width: 6rem;
        }
        .masthead-meta {
            font-size: 0.625rem;
            letter-spacing: 0.22em;
        }
    }
</style>
